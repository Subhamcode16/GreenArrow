{
  "name": "greenarrow-pro",
  "displayName": "GreenArrow Pro",
  "description": "Production-ready agentic memory bridge with auto-lifecycle management.",
  "version": "1.0.0",
  "publisher": "greenarrow",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "greenarrow-explorer",
          "title": "GreenArrow",
          "icon": "logo.svg"
        }
      ]
    },
    "views": {
      "greenarrow-explorer": [
        {
          "type": "webview",
          "id": "greenarrow-hub-view",
          "name": "Active Context"
        }
      ]
    },
    "commands": [
      {
        "command": "greenarrow.refresh",
        "title": "Refresh Context",
        "icon": "$(refresh)"
      },
      {
        "command": "greenarrow.copySnapshot",
        "title": "Copy XML Handoff"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3",
    "@vscode/test-electron": "^2.3.9"
  },
  "dependencies": {
    "axios": "^1.6.7"
  }
}
